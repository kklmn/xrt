<?xml version="1.0" encoding="utf-8"?>
<Project>
	<Beams type="prop">
		<None type="flat"></None>
		<geometricSource01_global type="flat"></geometricSource01_global>
		<gridAperture01_local type="flat"></gridAperture01_local>
		<screen01_local type="flat"></screen01_local>
		<gridBeamStop01_local type="flat"></gridBeamStop01_local>
	</Beams>
	<Materials type="prop">
	</Materials>
	<BeamLine type="value">
		<properties type="prop">
			<azimuth type="param">0.0</azimuth>
			<height type="param">0.0</height>
			<alignE type="param">auto</alignE>
			<fileName type="param">None</fileName>
			<name type="param">BeamLine</name>
			<description type="param">None</description>
		</properties>
		<_object type="param">xrt.backends.raycing.BeamLine</_object>
		<geometricSource01 type="value">
			<properties type="prop">
				<bl type="param">BeamLine</bl>
				<name type="param">geometricSource01</name>
				<center type="param">(0, 0, 0)</center>
				<pitch type="param">0</pitch>
				<roll type="param">0</roll>
				<yaw type="param">0</yaw>
				<nrays type="param">100000</nrays>
				<distx type="param">normal</distx>
				<dx type="param">0.32</dx>
				<disty type="param">None</disty>
				<dy type="param">0</dy>
				<distz type="param">normal</distz>
				<dz type="param">0.18</dz>
				<distxprime type="param">normal</distxprime>
				<dxprime type="param">0.001</dxprime>
				<distzprime type="param">normal</distzprime>
				<dzprime type="param">0.001</dzprime>
				<distE type="param">lines</distE>
				<energies type="param">(9000.0,)</energies>
				<polarization type="param">horizontal</polarization>
				<filamentBeam type="param">False</filamentBeam>
				<uniformRayDensity type="param">False</uniformRayDensity>
			</properties>
			<_object type="param">xrt.backends.raycing.sources.geoms.GeometricSource</_object>
			<shine type="prop">
				<parameters type="prop">
					<toGlobal type="param">True</toGlobal>
					<withAmplitudes type="param">False</withAmplitudes>
					<accuBeam type="param">None</accuBeam>
				</parameters>
				<_object type="param">xrt.backends.raycing.sources.geoms.GeometricSource.shine</_object>
				<output type="prop">
					<beamGlobal type="param">geometricSource01_global</beamGlobal>
				</output>
			</shine>
		</geometricSource01>
		<gridAperture01 type="value">
			<properties type="prop">
				<bl type="param">BeamLine</bl>
				<name type="param">gridAperture01</name>
				<center type="param">[0.0, 5000.0, 0.0]</center>
				<x type="param">[1.0, -0.0, 0.0]</x>
				<z type="param">[0.0, 0.0, 1.0]</z>
				<alarmLevel type="param">None</alarmLevel>
				<dx type="param">0.5</dx>
				<dz type="param">0.5</dz>
				<px type="param">1.0</px>
				<pz type="param">1.0</pz>
				<nx type="param">1</nx>
				<nz type="param">1</nz>
			</properties>
			<_object type="param">xrt.backends.raycing.apertures.GridAperture</_object>
			<propagate type="prop">
				<parameters type="prop">
					<beam type="param">geometricSource01_global</beam>
					<needNewGlobal type="param">False</needNewGlobal>
				</parameters>
				<_object type="param">xrt.backends.raycing.apertures.GridAperture.propagate</_object>
				<output type="prop">
					<beamLocal type="param">gridAperture01_local</beamLocal>
				</output>
			</propagate>
		</gridAperture01>
		<gridBeamStop01 type="value">
			<properties type="prop">
				<bl type="param">BeamLine</bl>
				<name type="param">gridBeamStop01</name>
				<center type="param">[0, 5500, 0]</center>
				<x type="param">auto</x>
				<z type="param">auto</z>
				<alarmLevel type="param">None</alarmLevel>
				<dx type="param">0.5</dx>
				<dz type="param">0.5</dz>
				<px type="param">1.0</px>
				<pz type="param">1.0</pz>
				<nx type="param">1</nx>
				<nz type="param">1</nz>
			</properties>
			<_object type="param">xrt.backends.raycing.apertures.GridBeamStop</_object>
			<propagate type="prop">
				<parameters type="prop">
					<beam type="param">geometricSource01_global</beam>
					<needNewGlobal type="param">False</needNewGlobal>
				</parameters>
				<_object type="param">xrt.backends.raycing.apertures.GridBeamStop.propagate</_object>
				<output type="prop">
					<beamLocal type="param">gridBeamStop01_local</beamLocal>
				</output>
			</propagate>
		</gridBeamStop01>
		<screen01 type="value">
			<properties type="prop">
				<bl type="param">BeamLine</bl>
				<name type="param">screen01</name>
				<center type="param">[0.0, 10000.0, 0.0]</center>
				<x type="param">[1.0, -0.0, 0.0]</x>
				<z type="param">[0.0, 0.0, 1.0]</z>
				<compressX type="param">None</compressX>
				<compressZ type="param">None</compressZ>
				<limPhysX type="param">[0.0, 0.0]</limPhysX>
				<limPhysY type="param">[0.0, 0.0]</limPhysY>
				<cLimits type="param">[0.0, 0.0]</cLimits>
				<histShape type="param">[256, 256]</histShape>
			</properties>
			<_object type="param">xrt.backends.raycing.screens.Screen</_object>
			<expose type="prop">
				<parameters type="prop">
					<beam type="param">geometricSource01_global</beam>
					<onlyPositivePath type="param">False</onlyPositivePath>
					<withHistogram type="param">False</withHistogram>
				</parameters>
				<_object type="param">xrt.backends.raycing.screens.Screen.expose</_object>
				<output type="prop">
					<beamLocal type="param">screen01_local</beamLocal>
				</output>
			</expose>
		</screen01>
	</BeamLine>
	<FigureErrors type="prop">
	</FigureErrors>
	<plots type="value">
	</plots>
	<run_ray_tracing type="prop">
		<plots type="param">plots</plots>
		<repeats type="param">1</repeats>
		<updateEvery type="param">1</updateEvery>
		<pickleEvery type="param">None</pickleEvery>
		<energyRange type="param">None</energyRange>
		<backend type="param">raycing</backend>
		<beamLine type="param">BeamLine</beamLine>
		<threads type="param">1</threads>
		<processes type="param">1</processes>
		<generator type="param">None</generator>
		<generatorArgs type="param">[]</generatorArgs>
		<generatorKWargs type="param">auto</generatorKWargs>
		<globalNorm type="param">0</globalNorm>
		<afterScript type="param">None</afterScript>
		<afterScriptArgs type="param">[]</afterScriptArgs>
		<afterScriptKWargs type="param">{}</afterScriptKWargs>
		<_object type="param">xrt.runner.run_ray_tracing</_object>
	</run_ray_tracing>
